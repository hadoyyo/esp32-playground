  configTime(gmtOffset_sec, 0, ntpServer);

  delay(1000);

  tft.fillRoundRect(1, -5, 239, 30, 4, 0x4208);
  
  tft.setTextColor(0xFFFF);
  tft.setFreeFont();
  
  tft.setTextSize(2);
  tft.drawString("Temperature", 9, 43);
  tft.drawString("Humidity", 9, 162);
  
  tft.setTextSize(5);
  tft.fillRect(172, 92, 5, 5, TFT_WHITE);
  tft.drawString("C", 183, 92);
  tft.drawString("%", 183, 207);
  
  tft.fillEllipse(119, 316, 124, 10, 0x8E09);
}

void updateClock() {
  tft.setTextSize(2);

  struct tm timeinfo;

  if (!getLocalTime(&timeinfo)) return;

  char dateStr[20];
  char timeStr[10];

  strftime(dateStr, sizeof(dateStr), "%d.%m.%Y", &timeinfo);
  strftime(timeStr, sizeof(timeStr), "%H:%M", &timeinfo);

  String date = String(dateStr);
  String time = String(timeStr);

  if (date != lastDate) {
    tft.fillRoundRect(4, 4, 105, 20, 4, 0x4208);
    tft.setTextSize(2);
    tft.drawString(date, 6, 6);
    lastDate = date;
  }

  if (time != lastTime) {
    tft.fillRoundRect(175, 4, 60, 20, 4, 0x4208);
    tft.drawString(time, 175, 6);
    lastTime = time;
  }

  colonVisible = !colonVisible;

  tft.fillRect(199, 4, 8, 20, 0x4208);

  if (colonVisible) {
    tft.drawString(":", 199, 6);
  }
}

void updateSensor() {

  TempAndHumidity values = dht.getTempAndHumidity();

  if (dht.getStatus() != 0) {
    return;
  }

  int temp = (int)values.temperature;
  int humi = (int)values.humidity;

  if (!firstRead && temp == lastTemp && humi == lastHumi) {
    return;
  }

  tft.setTextSize(5);

  // temperature
  if (firstRead || temp != lastTemp) {

    tft.fillRect(90, 90, 75, 40, TFT_BLACK);
    tft.drawString(String(temp), 100, 92);

    if (temp < 24) {
      tft.pushImage(23, 69, 45, 80, image_temp_cold_pixels);
    }
    else if (temp < 28) {
      tft.pushImage(23, 69, 45, 80, image_temp_normal_pixels);
    }
    else {
      tft.pushImage(23, 69, 45, 80, image_temp_hot_pixels);
    }
  }

  // humidity
  if (firstRead || humi != lastHumi) {

    tft.fillRect(90, 205, 75, 40, TFT_BLACK);
    tft.drawString(String(humi), 100, 207);

    if (humi < 30) {
      tft.pushImage(-4, 190, 100, 64, image_humi_low_pixels);
    }
    else if (humi < 60) {
      tft.pushImage(-4, 190, 100, 64, image_humi_normal_pixels);
    }
    else {
      tft.pushImage(-4, 190, 100, 64, image_humi_high_pixels);
    }
  }

  // cat
  if (firstRead || temp != lastTemp || humi != lastHumi) {

    if (temp < 24 && humi < 60) {
      tft.pushImage(99, 256, 50, 50, image_cat_cold_pixels);
    }
    else if (temp < 28 && humi < 60) {
      tft.pushImage(99, 256, 50, 50, image_cat_normal_pixels);
    }
    else if (temp >= 28 && humi < 60) {
      tft.pushImage(99, 256, 50, 50, image_cat_hot_pixels);
    }
    else {
      tft.pushImage(99, 256, 50, 50, image_cat_rainy_pixels);
    }
  }

  lastTemp = temp;
  lastHumi = humi;
  firstRead = false;
}

void loop() {

  if (millis() - lastClockUpdate > 500) {
    updateClock();
    lastClockUpdate = millis();
  }

  if (millis() - lastSensorUpdate > 2000) {
    updateSensor();
    lastSensorUpdate = millis();
  }
}
